APP_ENV=local
ALLOW_INTERNAL_MODEL=false
INTERNAL_MODEL_BASE_URL=
INTERNAL_MODEL_API_KEY=
INTERNAL_MODEL_NAME=
NO_PUBLIC_NETWORK=true
